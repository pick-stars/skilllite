{
  "name": "skilllite-assistant",
  "private": true,
  "version": "0.1.29",
  "description": "Tauri desktop UI. Vite: single config file vite.config.ts (see README § Vite 配置); do not add a parallel vite.config.js.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "test:llm-fallback": "node --test scripts/test-llm-scenario-fallback.cjs",
    "verify:webkit-bundle": "npm run build && node scripts/verify-no-lookbehind-in-dist.mjs",
    "preview": "vite preview",
    "tauri": "tauri",
    "icon": "tauri icon app-icon.png --output src-tauri/icons",
    "prebuild:tauri": "bash scripts/prebuild-skilllite.sh",
    "tauri:build": "cross-env CI=true tauri build"
  },
  "dependencies": {
    "@codemirror/lang-cpp": "^6.0.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-go": "^6.0.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-rust": "^6.0.2",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/lang-yaml": "^6.1.3",
    "@tanstack/react-virtual": "^3.13.24",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-global-shortcut": "^2.3.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@uiw/codemirror-theme-basic": "^4.25.9",
    "@uiw/codemirror-themes": "^4.25.9",
    "@uiw/react-codemirror": "^4.25.9",
    "highlight.js": "^11.11.1",
    "mdast-util-gfm-footnote": "^2.1.0",
    "mdast-util-gfm-strikethrough": "^2.0.0",
    "mdast-util-gfm-table": "^2.0.0",
    "mdast-util-gfm-task-list-item": "^2.0.0",
    "micromark-extension-gfm-footnote": "^2.1.0",
    "micromark-extension-gfm-strikethrough": "^2.1.0",
    "micromark-extension-gfm-table": "^2.1.1",
    "micromark-extension-gfm-task-list-item": "^2.1.0",
    "micromark-util-combine-extensions": "^2.0.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "unified": "^11.0.5",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.0",
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "cross-env": "^10.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "~6.0.3",
    "vite": "^6.0.1"
  }
}
